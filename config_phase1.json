  "strategies": {
    "enabled": ["dividend", "growth", "value"],
    "dividend": {
      "name": "DividendStrategy",
      "enabled": true,
      "description": "配当利回り重視",
      "weights": {
        "dividend_yield": 0.40,
        "roe": 0.15,
        "fcf_coverage": 0.25,
        "payout_ratio": 0.10,
        "doe": 0.10
      },
      "normalization": {
        "method": "min_max",
        "percentile_min": 5,
        "percentile_max": 95
      }
    },
    "growth": {
      "name": "GrowthStrategy",
      "enabled": true,
      "description": "成長率重視",
      "weights": {
        "eps_growth": 0.40,
        "revenue_growth": 0.20,
        "fcf_growth": 0.20,
        "roe": 0.20
      },
      "normalization": {
        "method": "min_max",
        "percentile_min": 5,
        "percentile_max": 95
      }
    },
    "value": {
      "name": "ValueStrategy",
      "enabled": true,
      "description": "割安株重視",
      "weights": {
        "per": 0.35,
        "pbr": 0.25,
        "roe": 0.20,
        "doe": 0.20
      },
      "normalization": {
        "method": "min_max",
        "percentile_min": 5,
        "percentile_max": 95
      },
      "invert_metrics": ["per", "pbr", "doe"]
    }
  },

  "output": {
    "formats": ["console", "csv", "excel", "json"],
    "console": {
      "enabled": true,
      "verbose": true,
      "show_metadata": true
    },
    "csv": {
      "enabled": false,
      "output_path": "./results/phase1_results.csv",
      "include_metadata": true
    },
    "excel": {
      "enabled": false,
      "output_path": "./results/phase1_results.xlsx",
      "include_metadata": true,
      "sheet_per_strategy": true
    },
    "json": {
      "enabled": false,
      "output_path": "./results/phase1_results.json"
    }
  },

  "snapshot": {
    "enabled": true,
    "storage_path": "./snapshots",
    "format": "json",
    "compress": false,
    "retention_days": 90
  },

  "logging": {
    "level": "INFO",
    "format": "%(asctime)s [%(levelname)s] %(name)s: %(message)s",
    "handlers": ["console", "file"],
    "file_path": "./logs/phase1.log"
  },

  "error_handling": {
    "null_tolerance": "ignore",
    "null_tolerance_description": "Null値は無視して処理を続ける",
    "error_strategy": "continue",
    "error_strategy_description": "エラーが発生しても処理を続ける",
    "skip_invalid_companies": true,
    "skip_invalid_companies_description": "データが不完全な企業はスキップ"
  },

  "validation": {
    "phase_1": {
      "expected_results": {
        "dividend_strategy": {
          "top_1": {
            "code": "1143",
            "name": "FPG",
            "reason": "配当利回り最高 6.2%"
          },
          "top_3_codes": ["1143", "2914", "3284"]
        },
        "growth_strategy": {
          "top_1": {
            "code": "6861",
            "name": "キーエンス",
            "reason": "EPS成長率最高 35%"
          },
          "top_3_codes": ["6861", "9984", "6326"]
        },
        "value_strategy": {
          "bottom_3_codes": ["6861", "2413", "4755"],
          "reason": "PER が高い企業は下位"
        }
      },
      "checks": [
        "3つの Strategy が異なるランキングを出しているか",
        "キーエンス（外れ値）が Value で下位、Growth で高位か",
        "楽天（赤字、Null）でエラーが出ていないか",
        "Snapshot ファイルが 3つ保存されているか"
      ]
    }
  }
}
