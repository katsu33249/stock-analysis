{
  "system": {
    "name": "Stock Analysis Platform v3.0",
    "version": "3.0.0",
    "description": "設定ファイル駆動の機敏な株式分析システム"
  },

  "phase": {
    "current": "phase_1",
    "phases": {
      "phase_1": {
        "name": "テスト実行",
        "description": "15社でStrategy・Snapshot・正規化を検証",
        "num_companies": 15,
        "duration_minutes": 3,
        "objective": [
          "Strategy パターンが正しく動作するか",
          "Snapshot 機能が正常に保存されるか",
          "正規化ロジックが期待通りか",
          "RateLimiter が API 制限を守るか",
          "ログシステムでデバッグ可能か"
        ]
      },
      "phase_2": {
        "name": "検証実行",
        "description": "100社でStrategy の戦略性を検証",
        "num_companies": 100,
        "duration_minutes": 25,
        "objective": [
          "各 Strategy が異なるランキングを出しているか",
          "ランキングに説得力があるか",
          "ウォッチリスト機能が正常か"
        ]
      },
      "phase_3": {
        "name": "本番運用",
        "description": "全企業（500+社）で本番環境確認",
        "num_companies": 500,
        "duration_minutes": 15,
        "objective": [
          "全企業に対して安定稼働",
          "GitHub Actions で定期実行",
          "Discord への通知が正常"
        ]
      }
    }
  },

  "data_sources": {
    "jquants": {
      "api_url": "https://api.jquants.com/v2",
      "auth_method": "header",
      "auth_key": "x-api-key",
      "rate_limit": {
        "requests": 25,
        "window_seconds": 60
      },
      "endpoints": {
        "equities": "/equities",
        "quotes": "/markets/quotes",
        "financials": "/fins/statements"
      }
    },
    "edinet": {
      "api_url": "https://disclosure.edinet-fsa.go.jp/api/v2",
      "auth_method": "none",
      "enabled": false
    }
  },

